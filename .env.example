# Required — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Required — any model id available on OpenRouter, e.g. openai/gpt-4o-mini
OPENROUTER_DEFAULT_MODEL=

# Optional — enables web_search/web_crawl tools in Plan/Ask mode
# Get a key at https://www.firecrawl.dev
FIRECRAWL_API_KEY=


